# MANIFEST.in for nuclockutils
# With setuptools_scm, all git-tracked files are included by default
# Use prune/exclude to remove files that shouldn't be in the distribution

include README.rst
include CHANGES.rst
include pyproject.toml

recursive-include nuclockutils *.pyx *.c *.pxd *.fits *.csv *.evt
recursive-include docs *
recursive-include licenses *
recursive-include scripts *

prune build
prune docs/_build
prune docs/api
prune .github

global-exclude *.pyc *.o
